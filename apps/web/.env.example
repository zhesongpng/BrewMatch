# BrewMatch front-end environment variables.
# Copy to .env.local for local dev; set the same key in Vercel's project settings.

# Base URL of the Python "brain" API (Goal A — live on Render).
# Used by the front-end (B2 onward) to fetch recommendations, diagnosis, etc.
NEXT_PUBLIC_BREWMATCH_API_URL=https://brewmatch-iki5.onrender.com

# Supabase login (Goal C). Both values are PUBLIC by design — the anon key is
# meant to ship in the browser. Find them in Supabase → Project Settings → API.
# Until BOTH are set, the app runs anonymously (on-device ids) and the sign-in
# screen shows a "coming soon" message — login stays dark with no setup.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
